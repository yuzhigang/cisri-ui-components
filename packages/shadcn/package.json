{
  "name": "@cisri/shadcn",
  "version": "1.0.0",
  "description": "Shared shadcn/ui primitives for @cisri business components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && vite build",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cisri/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@radix-ui/react-checkbox": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.300.0"
  },
  "peerDependenciesMeta": {
    "@radix-ui/react-checkbox": { "optional": true },
    "@radix-ui/react-dialog": { "optional": true },
    "@radix-ui/react-label": { "optional": true },
    "@radix-ui/react-scroll-area": { "optional": true },
    "@radix-ui/react-select": { "optional": true },
    "@radix-ui/react-separator": { "optional": true },
    "@radix-ui/react-slot": { "optional": true },
    "class-variance-authority": { "optional": true },
    "lucide-react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "@vitejs/plugin-react": "^4.2.0"
  }
}